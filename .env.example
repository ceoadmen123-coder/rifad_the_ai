# RIYAD THE AI — Environment Variables

# Web server port (Render sets this automatically)
PORT=3000

# Optional: Custom auth directory path
# AUTH_DIR=/custom/path/auth_info

# Your Render service URL (enables self-ping to prevent free-tier sleep)
# Set this after first deploy, e.g.:
# RENDER_EXTERNAL_URL=https://riyad-the-ai.onrender.com
RENDER_EXTERNAL_URL=
